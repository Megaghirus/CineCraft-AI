# ===== REQUIRED =====
# Google Gemini API Key - for text generation (Gemini 2.5 Pro) and video generation (Veo 3)
GEMINI_API_KEY="your_gemini_api_key_here"

# ===== VIDEO GENERATION =====
# VideoGen API Key - unlocks Sora 2, Kling 3, Seedance 2, Wan 2.5
# Get your key at: https://videogenapi.com
VIDEOGEN_API_KEY="your_videogen_api_key_here"

# ===== VOICE SYNTHESIS =====
# ElevenLabs API Key - for text-to-speech voice generation (supports RO/EN/RU)
# Get your key at: https://elevenlabs.io
ELEVENLABS_API_KEY="your_elevenlabs_api_key_here"

# ElevenLabs default voice ID (Rachel - multilingual, works for EN/RO/RU)
# You can change this to any voice ID from your ElevenLabs account
ELEVENLABS_DEFAULT_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# ===== LIP-SYNC =====
# Sync.Labs API Key - for lip-sync synchronization between video and audio
# Get your key at: https://synclabs.so
# NOTE: Requires publicly accessible video/audio URLs (use in production with a real domain)
SYNCLABS_API_KEY="your_synclabs_api_key_here"

# ===== SERVER =====
# Application base URL - required for Sync.Labs (must be publicly accessible for lipsync)
APP_URL="http://localhost:3000"
